class Solution {
    public int lengthOfLongestSubstring(String s) {
        int n = s.length();
        int right = 0 ,left = 0;
        int maxlen =0;
        HashSet<Character> set = new HashSet<>();

        while(right< n)
        {
            char c = s.charAt(right);
            if(!set.contains(c))
            {
                set.add(c);
                right++;
                 maxlen = Math.max(maxlen , right -left);
            }
            else
            {
                set.remove(s.charAt(left));
                left++; 
            }
        }
        return maxlen;
    }
}
